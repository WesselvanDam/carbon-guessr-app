<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+): override with native SplashScreen API attributes.
         The core-splashscreen library maps these to the compat attributes above,
         but declaring them here ensures the OS picks up the correct values even
         without the compat layer. -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/launch_background_color</item>
        <item name="windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/launch_background_color</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
