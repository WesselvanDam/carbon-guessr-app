<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night-mode variant – reuses the same branded splash theme. -->
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/launch_background_color</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <!-- Keeps the window background consistent with the splash so there is no
         colour flash when the Flutter engine draws its first frame. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background_color</item>
    </style>
</resources>
